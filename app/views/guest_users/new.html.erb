<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Enter Your Details</h1>
  <p class="text-gray-600 mb-6">Please provide your contact information to continue with your booking.</p>
  
  <%= form_with(model: @guest_user, local: true) do |form| %>
    <% if @guest_user.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <h2 class="text-lg font-semibold"><%= pluralize(@guest_user.errors.count, "error") %> prohibited this guest user from being saved:</h2>
        <ul class="list-disc list-inside">
          <% @guest_user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <%= hidden_field_tag :booking_id, params[:booking_id] %>
  
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <%= form.label :first_name, class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= form.text_field :first_name, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>
      
      <div>
        <%= form.label :last_name, class: "block text-gray-700 text-sm font-bold mb-2" %>
        <%= form.text_field :last_name, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
      </div>
    </div>
    
    <div class="mb-4">
      <%= form.label :email, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.email_field :email, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>
    
    <div class="mb-6">
      <%= form.label :phone, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= form.telephone_field :phone, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>
  
    <div class="flex items-center justify-between">
      <%= form.submit "Continue to Payment", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
    </div>
  <% end %>
</div>

<div class="mt-8 text-center">
  <p class="text-gray-600">Already have an account? <%= link_to "Login", login_path, class: "text-blue-600 hover:underline" %></p>
</div>
