<div class="max-w-3xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-800 mb-6">Booking Details</h1>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <div class="flex justify-between items-center mb-6">
      <div>
        <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded">
          Status: <%= @booking.status.capitalize %>
        </span>
        
        <span class="bg-<%= @booking.payment_status == 'paid' ? 'green' : 'yellow' %>-100 text-<%= @booking.payment_status == 'paid' ? 'green' : 'yellow' %>-800 text-xs font-medium ml-2 px-2.5 py-0.5 rounded">
          Payment: <%= @booking.payment_status.capitalize %>
        </span>
      </div>
      
      <% if @booking.can_cancel? %>
        <%= button_to "Cancel Booking", cancel_booking_path(@booking), method: :patch, class: "text-red-600 hover:text-red-800 text-sm font-medium", data: { confirm: "Are you sure you want to cancel this booking?" } %>
      <% end %>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h2 class="text-xl font-semibold mb-4">Ride Information</h2>
        
        <div class="mb-4">
          <p class="text-gray-600 text-sm">Pickup Location</p>
          <p class="text-gray-900"><%= @booking.pickup_location %></p>
        </div>
        
        <div class="mb-4">
          <p class="text-gray-600 text-sm">Dropoff Location</p>
          <p class="text-gray-900"><%= @booking.dropoff_location %></p>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-gray-600 text-sm">Distance</p>
            <p class="text-gray-900"><%= number_with_precision(@booking.distance, precision: 2) %> km</p>
          </div>
          
          <div>
            <p class="text-gray-600 text-sm">Duration</p>
            <p class="text-gray-900"><%= (@booking.duration / 60).to_i %> min</p>
          </div>
        </div>
        
        <% if @booking.pickup_note.present? %>
          <div class="mt-4 p-3 bg-gray-50 rounded-lg">
            <p class="text-gray-600 text-sm">Pickup Note</p>
            <p class="text-gray-900"><%= @booking.pickup_note %></p>
          </div>
        <% end %>
      </div>
      
      <div>
        <div id="map" class="h-48 rounded-lg mb-4"></div>
        
        <div class="bg-gray-50 p-4 rounded-lg">
          <h3 class="font-semibold text-gray-800 mb-2">Payment Details</h3>
          
          <div class="flex justify-between mb-1">
            <span class="text-gray-600">Method:</span>
            <span class="text-gray-900"><%= @booking.payment_method.titleize %></span>
          </div>
          
          <div class="flex justify-between mb-1">
            <span class="text-gray-600">Status:</span>
            <span class="text-gray-900"><%= @booking.payment_status.capitalize %></span>
          </div>
          
          <div class="flex justify-between border-t border-gray-200 mt-2 pt-2">
            <span class="text-gray-800 font-semibold">Total:</span>
            <span class="text-gray-900 font-bold">$<%= number_with_precision(@booking.estimated_price, precision: 2) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="flex justify-between">
    <%= link_to "Back to Bookings", bookings_path, class: "text-blue-600 hover:text-blue-800" %>
    <%= link_to "Book Another Ride", new_booking_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize the map
    const map = new google.maps.Map(document.getElementById('map'), {
      center: { lat: <%= @booking.pickup_lat %>, lng: <%= @booking.pickup_lng %> },
      zoom: 12
    });
    
    // Add markers for pickup and dropoff
    const pickupLocation = new google.maps.LatLng(<%= @booking.pickup_lat %>, <%= @booking.pickup_lng %>);
    const dropoffLocation = new google.maps.LatLng(<%= @booking.dropoff_lat %>, <%= @booking.dropoff_lng %>);
    
    const pickupMarker = new google.maps.Marker({
      position: pickupLocation,
      map: map,
      icon: {
        url: 'http://maps.google.com/mapfiles/ms/icons/green-dot.png',
        scaledSize: new google.maps.Size(40, 40)
      },
      title: 'Pickup Location'
    });
    
    const dropoffMarker = new google.maps.Marker({
      position: dropoffLocation,
      map: map,
      icon: {
        url: 'http://maps.google.com/mapfiles/ms/icons/red-dot.png',
        scaledSize: new google.maps.Size(40, 40)
      },
      title: 'Dropoff Location'
    });
    
    // Draw route between pickup and dropoff
    const directionsService = new google.maps.DirectionsService();
    const directionsRenderer = new google.maps.DirectionsRenderer({
      map: map,
      suppressMarkers: true
    });
    
    const request = {
      origin: pickupLocation,
      destination: dropoffLocation,
      travelMode: google.maps.TravelMode.DRIVING
    };
    
    directionsService.route(request, function(result, status) {
      if (status === google.maps.DirectionsStatus.OK) {
        directionsRenderer.setDirections(result);
      }
    });
  });
</script>
