<nav class="bg-white shadow">
  <div class="container mx-auto px-4">
    <div class="flex justify-between h-16">
      <div class="flex">
        <div class="flex-shrink-0 flex items-center">
          <%= link_to root_path do %>
            <h1 class="text-xl font-bold text-blue-600">Car Booking</h1>
          <% end %>
        </div>
      </div>
      
      <div class="flex items-center">
        <% if logged_in? %>
          <div class="ml-4 flex items-center">
            <div class="relative">
              <div class="flex space-x-4">
                <%= link_to "My Bookings", bookings_path, class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium" %>
                <%= link_to "Profile", user_path(current_user), class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium" %>
                <%= button_to "Logout", logout_path, method: :delete, class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium" %>
              </div>
            </div>
          </div>
        <% else %>
          <div class="flex space-x-4">
            <%= link_to "Login", login_path, class: "text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Sign Up", new_user_path, class: "bg-blue-600 text-white hover:bg-blue-700 px-3 py-2 rounded-md text-sm font-medium" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav> 